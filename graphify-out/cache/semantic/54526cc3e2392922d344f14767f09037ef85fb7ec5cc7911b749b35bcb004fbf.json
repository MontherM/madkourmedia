{"nodes": [{"id": "_claude_skills_graphify_references_query_query_expansion", "label": "Constrained Query Expansion", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": "Step 0", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The query CLI matches via case-folded substring + IDF with no stemming or synonyms, so vocabulary mismatch returns 0 hits; expanding only with tokens from the graph's own vocabulary fixes this without inventing tokens"}, {"id": "_claude_skills_graphify_references_query_bfs_dfs_traversal", "label": "BFS/DFS Graph Traversal", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": "Step 1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "BFS for broad context (what is X connected to), DFS depth-limited to 6 for tracing a specific chain"}, {"id": "_claude_skills_graphify_references_query_save_result_loop", "label": "save-result Feedback Loop", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Answers are saved back into the graph so the next --update extracts each Q&A as a node, improving future queries"}, {"id": "_claude_skills_graphify_references_query_work_memory", "label": "Work Memory (reflect / LESSONS.md)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Outcome tags (useful/dead_end/corrected) feed graphify reflect, which maintains LESSONS.md listing preferred sources, known dead ends and corrections for future sessions"}], "edges": [{"source": "_claude_skills_graphify_references_query_query_expansion", "target": "_claude_skills_graphify_references_