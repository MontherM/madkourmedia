{"nodes": [{"id": "_claude_skills_graphify_skill_graphify_pipeline", "label": "Graphify Build Pipeline", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 1-9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_ast_extraction", "label": "Structural AST Extraction", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic and free - code corpora need no LLM and no API key; runs in parallel with semantic extraction to save 5-15s on large corpora"}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction via Parallel Subagents", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Subagents dispatched in one message run in parallel (5-10x faster than reading files one-by-one); must be general-purpose type because Explore is read-only and silently drops chunk files"}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cache check before dispatch avoids re-extracting unchanged files; stale .graphify_cached.json is deleted so Part C never merges leftovers (#1392)"}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection and Labeling", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 4-5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "God Nodes Analysis", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only integrity gate that surfaces edge collapse, dangling endpoints and self-loops - the silent-corruption modes of incremental updates and AST/LLM id mismatches; never aborts, but warnings must be surfaced per the Honesty Rules"}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Graph Shrink Guard", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json refuses to write when the new graph is smaller than the existing graph.json (#479) so an empty or failed extraction never clobbers a good graph; report and analysis sidecar are only written when the graph was actually written (#1392)"}, {"id": "_claude_skills_graphify_skill_fast_path_query", "label": "Fast Path for Existing Graph", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "What You Must Do When Invoked", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json exists and the request is a natural-language question, skip the build entirely and query - the graph is already built"}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Honesty Rules (Audit Trail)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Honesty Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge (use AMBIGUOUS when unsure), always show token cost, show raw cohesion scores - the EXTRACTED/INFERRED/AMBIGUOUS audit trail is the product's trust guarantee"}, {"id": "_claude_skills_graphify_skill_no_api_key_policy", "label": "No API Key Required Policy", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "graphify never blocks on an API key: code is extracted via AST with no LLM; semantic extraction uses Gemini only if a key is already set, otherwise the host agent itself is the LLM. Prompting for ANTHROPIC_API_KEY is defined as a misread of the skill"}], "edges": [{"source": "_claude_skills_graphify_skill_graphify_pipeline", "target": "_claude_skills_graphify_skill_ast_extraction", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_pipeline", "target": "_claude_skills_graphify_skill_semantic_extraction", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_semantic_extraction", "target": "_claude_skills_graphify_skill_extraction_cache", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_pipeline", "target": "_claude_skills_graphify_skill_community_detection", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 4-5", "weight": 1.0}, {"