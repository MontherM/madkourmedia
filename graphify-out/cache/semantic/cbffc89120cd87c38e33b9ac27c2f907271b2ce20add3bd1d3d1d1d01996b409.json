{"nodes": [{"id": "docs_content_strategie_marktanalyse_2026", "label": "Market Analysis 2026 (Demand Ranking)", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Demand order: AI agents & workflow automation first (Gartner: ~40% of enterprise apps with task-specific agents by end of 2026, most new roles no-code), then workflow design, prompting, context engineering, AI judgment - so course weight must shift from 'understand AI' to 'workflows & agents' where the paid tier begins"}, {"id": "docs_content_strategie_openai_academy_benchmark", "label": "OpenAI Academy Benchmark", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Strongest free competitor; its weaknesses define the differentiation: German/DACH examples, tool-agnostic (ChatGPT and Claude/Gemini/Perplexity/n8n), a real person, community, pass-based certificates with score, industry personas"}, {"id": "docs_content_strategie_didaktik_messlatte", "label": "7-Point Didactics Checklist", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Outcome over topic, one artifact per lesson, quick win in minute 1 (decides completion rates), 5-12 min single-skill videos, practice over watching, built-in repetition, honesty about limits (builds trust ad-driven courses never get)"}, {"id": "docs_content_strategie_soll_curriculum", "label": "Target Curriculum (3 Levels, 12 Lessons)", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a75", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Level 3 renamed from 'AI Master' to 'AI Workflows & Agenten' and made the pro-tier focus because that is where demand and willingness to pay converge; the old content had 4 basics lessons but only 1 agents lesson - the inverse of demand"}, {"id": "docs_content_strategie_hybrid_produktion", "label": "Hybrid Production (Face Front, AI Backstage)", "file_type": "rationale", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a76", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No AI avatars as the core: avatar videos are 2026 commodity nobody trusts and would destroy the strongest differentiator (a real DACH person showing how they work); AI handles scripts, shotlists, graphics, quizzes, subtitles while the human films one batch day per level - 20-30% talking head, 60-70% screen recording, 10% graphics"}, {"id": "docs_content_strategie_funnel", "label": "Visitor Funnel Strategy", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Landing sells transformation not features; Level 1 fully free as honest trial; prompt library .md export as lead magnet against newsletter; shorts from screen recordings as traffic source"}, {"id": "docs_content_strategie_context_engineering", "label": "Context Engineering", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Giving agents the right information (knowledge, tools, limits) rather than just the right question - replacing prompt engineering as the differentiator"}, {"id": "docs_content_strategie_prompt_bibliothek", "label": "Prompt Library (14+ Prompts, .md Export)", "file_type": "concept", "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a74", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "6 prompts felt empty; expanded to 14+ including agent/workflow prompts, exportable as .md for Obsidian/Notion users and reused as the lead magnet"}], "edges": [{"source": "docs_content_strategie_marktanalyse_2026", "target": "docs_content_strategie_soll_curriculum", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a71 \u2192 \u00a75", "weight": 1.0}, {"source": "docs_content_strategie_openai_academy_benchmark", "target": "docs_content_strategie_soll_curriculum", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a72", "weight": 1.0}, {"source": "docs_content_strategie_didaktik_messlatte", "target": "docs_content_strategie_soll_curriculum", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a73 \u2192 \u00a75", "weight": 1.0}, {"source": "docs_content_strategie_marktanalyse_2026", "target": "docs_content_strategie_context_engineering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a71 item 4", "weight": 1.0}, {"source": "docs_content_strategie_soll_curriculum", "target": "docs_content_strategie_context_engineering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a75 Level 3", "weight": 1.0}, {"source": "docs_content_strategie_funnel", "target": "docs_content_strategie_prompt_bibliothek", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/CONTENT-STRATEGIE.md", "source_location": "\u00a77 item 3", "weight": 1.0}, {"source": "docs_content_strategie_hybrid_produktion", "target": "docs_content_strategie_soll_curriculum", "relat